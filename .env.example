# 7Pacific Hydrogen storefront — environment variables
#
# Copy this file to `.env` and fill in the values for local development:
#   cp .env.example .env
#
# `.env` is gitignored and must never be committed. Secret values are populated
# by you (or pulled from Oxygen via `shopify hydrogen env pull`) — placeholders
# below describe what each value is and where it comes from. The fastest path to
# a populated local env is `shopify hydrogen link` followed by `env pull`.
#
# Legend:  [public]  = safe to expose to the browser / paste anywhere
#          [secret]  = sensitive; you set it, never share or commit the value

# --- Storefront API ---------------------------------------------------------
# [public]  Your myshopify domain, e.g. 7pacific.myshopify.com
PUBLIC_STORE_DOMAIN=
# [public]  Public Storefront API access token (channel- or app-minted)
PUBLIC_STOREFRONT_API_TOKEN=
# [secret]  Private (delegate) Storefront API token — server-side only
PRIVATE_STOREFRONT_API_TOKEN=
# [public]  Storefront API version. Hydrogen defaults this; pin only to override.
PUBLIC_STOREFRONT_API_VERSION=2026-04
# [public]  Numeric storefront id (used by Shopify Analytics)
PUBLIC_STOREFRONT_ID=

# --- Sessions ---------------------------------------------------------------
# [secret]  Session cookie signing secret. Generate with: openssl rand -hex 32
SESSION_SECRET=

# --- Customer Account API ---------------------------------------------------
# [public]  Customer Account API base URL (from Admin / `customer-account-push`)
PUBLIC_CUSTOMER_ACCOUNT_API_URL=
# [secret]  Customer Account API client id
PUBLIC_CUSTOMER_ACCOUNT_API_CLIENT_ID=

# --- Checkout ---------------------------------------------------------------
# [public]  Checkout domain (used by the privacy/consent banner + checkout links)
PUBLIC_CHECKOUT_DOMAIN=
